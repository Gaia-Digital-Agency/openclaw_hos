{
  "mcpServers": {
    "filesystem": {
      "command": "/home/azlan/.npm-global/bin/mcp-server-filesystem",
      "args": [
        "/opt/.openclaw-hos/workspace-main",
        "/opt/.openclaw-hos/workspace-booking",
        "/opt/.openclaw-hos/workspace-sales",
        "/opt/.openclaw-hos/workspace-fnb",
        "/opt/.openclaw-hos/workspace-event",
        "/opt/.openclaw-hos/workspace-maintenance",
        "/opt/.openclaw-hos/workspace-housekeeping",
        "/opt/.openclaw-hos/workspace-concierge",
        "/opt/.openclaw-hos/workspace-front",
        "/opt/.openclaw-hos/workspace-writer",
        "/opt/.openclaw-hos/workspace-calendar-manager",
        "/opt/.openclaw-hos/workspace-email-manager"
      ]
    },
    "fetch": {
      "command": "/home/azlan/.npm-global/bin/mcp-fetch",
      "args": []
    },
    "google-calendar": {
      "command": "/home/azlan/.npm-global/bin/google-calendar-mcp",
      "args": ["start"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/home/azlan/google-oauth/credentials.json"
      }
    },
    "gmail": {
      "command": "/home/azlan/.npm-global/bin/mcp-gmail",
      "args": [
        "--oauth-path", "/home/azlan/google-oauth/gmail-oauth.json",
        "--credentials-path", "/home/azlan/google-oauth/gmail-credentials.json"
      ]
    }
  }
}
